{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node server/index.js",
    "restartPolicy": {
      "type": "ON_FAILURE",
      "maxRetries": 3
    },
    "healthcheck": {
      "path": "/api/auth/verify",
      "port": 3000
    }
  }
}
